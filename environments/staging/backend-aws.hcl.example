# environments/staging/backend-aws.hcl.example
# Copy to backend-aws.hcl and fill in real values, then:
#   terraform init -backend-config=../environments/staging/backend-aws.hcl

bucket         = "REPLACE_ME_TFSTATE_BUCKET"
key            = "multicloud/aws/staging/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
dynamodb_table = "REPLACE_ME_LOCK_TABLE"
